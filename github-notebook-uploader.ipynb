  "cells": [
    {
      "cell_type": "code",
      "source": [
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "import os\n",
        "import re\n",
        "import csv\n",
        "import json\n",
        "import time\n",
        "import base64\n",
        "import getpass\n",
        "import requests\n",
        "from pathlib import Path\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# SETTINGS\n",
        "# ==========================================================\n",
        "\n",
        "NOTEBOOK_FOLDER = \"/content/drive/MyDrive/Colab Notebooks\"\n",
        "\n",
        "DRY_RUN = False\n",
        "# First run with True.\n",
        "# After checking the log, change to False.\n",
        "\n",
        "MAKE_REPOS_PRIVATE = False\n",
        "# False = create public repos\n",
        "\n",
        "MAKE_PRIVATE_EXISTING_REPOS_PUBLIC = True\n",
        "# If repo exists and is private, convert it to public and skip upload.\n",
        "\n",
        "REMOVE_NOTEBOOK_OUTPUTS = True\n",
        "\n",
        "OPENAI_MODEL = \"gpt-4.1-mini\"\n",
        "\n",
        "MAX_NOTEBOOK_SIZE_MB = 90\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# LOGIN INPUTS\n",
        "# ==========================================================\n",
        "\n",
        "GITHUB_USERNAME = input(\"Enter your GitHub username: \").strip()\n",
        "GITHUB_TOKEN =REDACTED_SECRET
        "\n",
        "\n",
        "# ==========================================================\n",
        "# SECRET PATTERNS\n",
        "# ==========================================================\n",
        "\n",
        "SECRET_PATTERNS =REDACTED_SECRET
        "    (\"OpenAI API key\", re.compile(r\"sk-[A-Za-z0-9_\\-]{20,}\")),\n",
        "    (\"GitHub token\", re.compile(r\"gh[pousr]_[A-Za-z0-9_]{20,}\")),\n",
        "    (\"Google API key\", re.compile(r\"AIza[0-9A-Za-z\\-_]{20,}\")),\n",
        "    (\"AWS access key\", re.compile(r\"AKIA[0-9A-Z]{16}\")),\n",
        "    (\"Private key block\", re.compile(\n",
        "        r\"-----BEGIN [A-Z ]*PRIVATE KEY-----[\\s\\S]*?-----END [A-Z ]*PRIVATE KEY-----\",\n",
        "        re.MULTILINE\n",
        "    )),\n",
        "]\n",
        "\n",
        "GENERIC_SECRET_ASSIGNMENT =REDACTED_SECRET
        "    r\"\"\"(?i)(api[_-]?key|secret|token|password|private[_-]?key|access[_-]?key)\\s*[:=REDACTED_SECRET
        ")\n",
        "\n",
        "GENERIC_SECRET_ENV =REDACTED_SECRET
        "    r\"\"\"(?i)^(.*?(API_KEY|SECRET|TOKEN|PASSWORD|PRIVATE_KEY|ACCESS_KEY).*?=REDACTED_SECRET
        "    re.MULTILINE\n",
        ")\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# TEXT / SANITIZE HELPERS\n",
        "# ==========================================================\n",
        "\n",
        "def sanitize_text(text):\n",
        "    findings = []\n",
        "    clean_text = str(text)\n",
        "\n",
        "    for label, pattern in SECRET_PATTERNS:\n",
        "        if pattern.search(clean_text):\n",
        "            findings.append(label)\n",
        "            clean_text = pattern.sub(\"REDACTED_SECRET\", clean_text)\n",
        "\n",
        "    if GENERIC_SECRET_ASSIGNMENT.search(clean_text):\n",
        "        findings.append(\"Generic secret assignment\")\n",
        "        clean_text = GENERIC_SECRET_ASSIGNMENT.sub(\n",
        "            \"REDACTED_SECRET_ASSIGNMENT =REDACTED_SECRET
        "            clean_text\n",
        "        )\n",
        "\n",
        "    if GENERIC_SECRET_ENV.search(clean_text):\n",
        "        findings.append(\"Generic env secret\")\n",
        "        clean_text = GENERIC_SECRET_ENV.sub(r\"\\1REDACTED_SECRET\", clean_text)\n",
        "\n",
        "    return clean_text, sorted(set(findings))\n",
        "\n",
        "\n",
        "def clean_repo_name(name):\n",
        "    repo = str(name).lower()\n",
        "    repo = repo.replace(\".ipynb\", \"\")\n",
        "    repo = re.sub(r\"[^a-z0-9]+\", \"-\", repo)\n",
        "    repo = repo.strip(\"-\")\n",
        "\n",
        "    if len(repo) > 80:\n",
        "        repo = repo[:80].strip(\"-\")\n",
        "\n",
        "    return repo or \"colab-notebook\"\n",
        "\n",
        "\n",
        "def clean_notebook_file_name(name):\n",
        "    clean_name = clean_repo_name(name)\n",
        "\n",
        "    if not clean_name.endswith(\".ipynb\"):\n",
        "        clean_name = clean_name + \".ipynb\"\n",
        "\n",
        "    return clean_name\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# GITHUB API HELPERS\n",
        "# ==========================================================\n",
        "\n",
        "def github_headers():\n",
        "    return {\n",
        "        \"Authorization\": f\"Bearer {GITHUB_TOKEN}\",\n",
        "        \"Accept\": \"application/vnd.github+json\",\n",
        "        \"X-GitHub-Api-Version\": \"2022-11-28\"\n",
        "    }\n",
        "\n",
        "\n",
        "def github_api(method, url, data=None, allow_fail=False):\n",
        "    response = requests.request(\n",
        "        method,\n",
        "        url,\n",
        "        headers=github_headers(),\n",
        "        json=data\n",
        "    )\n",
        "\n",
        "    if not allow_fail and response.status_code >= 400:\n",
        "        raise Exception(f\"GitHub API error {response.status_code}: {response.text}\")\n",
        "\n",
        "    return response\n",
        "\n",
        "\n",
        "def get_repo_info(repo_name):\n",
        "    url = f\"https://api.github.com/repos/{GITHUB_USERNAME}/{repo_name}\"\n",
        "    response = github_api(\"GET\", url, allow_fail=True)\n",
        "\n",
        "    if response.status_code != 200:\n",
        "        return None\n",
        "\n",
        "    return response.json()\n",
        "\n",
        "\n",
        "def repo_exists(repo_name):\n",
        "    return get_repo_info(repo_name) is not None\n",
        "\n",
        "\n",
        "def create_repo(repo_name, description):\n",
        "    url = \"https://api.github.com/user/repos\"\n",
        "\n",
        "    payload = {\n",
        "        \"name\": repo_name,\n",
        "        \"description\": description[:350],\n",
        "        \"private\": MAKE_REPOS_PRIVATE,\n",
        "        \"auto_init\": False\n",
        "    }\n",
        "\n",
        "    response = github_api(\"POST\", url, payload)\n",
        "\n",
        "    return response.json()\n",
        "\n",
        "\n",
        "def update_repo_description(repo_name, description):\n",
        "    url = f\"https://api.github.com/repos/{GITHUB_USERNAME}/{repo_name}\"\n",
        "\n",
        "    payload = {\n",
        "        \"description\": description[:350]\n",
        "    }\n",
        "\n",
        "    github_api(\"PATCH\", url, payload, allow_fail=True)\n",
        "\n",
        "\n",
        "def make_repo_public(repo_name):\n",
        "    url = f\"https://api.github.com/repos/{GITHUB_USERNAME}/{repo_name}\"\n",
        "\n",
        "    payload = {\n",
        "        \"private\": False\n",
        "    }\n",
        "\n",
        "    response = github_api(\"PATCH\", url, payload, allow_fail=True)\n",
        "\n",
        "    if response.status_code >= 400:\n",
        "        raise Exception(f\"Could not make repo public: {response.status_code} {response.text}\")\n",
        "\n",
        "    return \"Repo converted to public\"\n",
        "\n",
        "\n",
        "def get_file_sha(repo_name, file_path):\n",
        "    url = f\"https://api.github.com/repos/{GITHUB_USERNAME}/{repo_name}/contents/{file_path}\"\n",
        "    response = github_api(\"GET\", url, allow_fail=True)\n",
        "\n",
        "    if response.status_code == 200:\n",
        "        return response.json().get(\"sha\")\n",
        "\n",
        "    return None\n",
        "\n",
        "\n",
        "def upload_file_to_repo(repo_name, repo_path, content_bytes, message):\n",
        "    url = f\"https://api.github.com/repos/{GITHUB_USERNAME}/{repo_name}/contents/{repo_path}\"\n",
        "\n",
        "    encoded_content = base64.b64encode(content_bytes).decode(\"utf-8\")\n",
        "\n",
        "    payload = {\n",
        "        \"message\": message,\n",
        "        \"content\": encoded_content\n",
        "    }\n",
        "\n",
        "    sha = get_file_sha(repo_name, repo_path)\n",
        "\n",
        "    if sha:\n",
        "        payload[\"sha\"] = sha\n",
        "\n",
        "    response = github_api(\"PUT\", url, payload)\n",
        "\n",
        "    return response.json()\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# NOTEBOOK HELPERS\n",
        "# ==========================================================\n",
        "\n",
        "def notebook_has_code(notebook_data):\n",
        "    cells = notebook_data.get(\"cells\", [])\n",
        "\n",
        "    for cell in cells:\n",
        "        if cell.get(\"cell_type\") == \"code\":\n",
        "            source = cell.get(\"source\", \"\")\n",
        "\n",
        "            if isinstance(source, list):\n",
        "                source = \"\".join(source)\n",
        "\n",
        "            if str(source).strip():\n",
        "                return True\n",
        "\n",
        "    return False\n",
        "\n",
        "\n",
        "def clean_notebook(notebook_path):\n",
        "    with open(notebook_path, \"r\", encoding=\"utf-8\", errors=\"ignore\") as f:\n",
        "        notebook = json.load(f)\n",
        "\n",
        "    secret_findings =REDACTED_SECRET
        "\n",
        "    cells = notebook.get(\"cells\", [])\n",
        "\n",
        "    for cell in cells:\n",
        "        source = cell.get(\"source\", \"\")\n",
        "\n",
        "        if isinstance(source, list):\n",
        "            source_text = \"\".join(source)\n",
        "            clean_source, findings = sanitize_text(source_text)\n",
        "            cell[\"source\"] = clean_source.splitlines(keepends=True)\n",
        "        else:\n",
        "            clean_source, findings = sanitize_text(str(source))\n",
        "            cell[\"source\"] = clean_source\n",
        "\n",
        "        if findings:\n",
        "            secret_findings.extend(findings)\n",
        "\n",
        "        if REMOVE_NOTEBOOK_OUTPUTS and cell.get(\"cell_type\") == \"code\":\n",
        "            cell[\"outputs\"] = []\n",
        "            cell[\"execution_count\"] = None\n",
        "\n",
        "    notebook[\"metadata\"] = notebook.get(\"metadata\", {})\n",
        "\n",
        "    if \"widgets\" in notebook[\"metadata\"]:\n",
        "        del notebook[\"metadata\"][\"widgets\"]\n",
        "\n",
        "    clean_json = json.dumps(notebook, indent=2, ensure_ascii=False)\n",
        "\n",
        "    clean_json, extra_findings = sanitize_text(clean_json)\n",
        "\n",
        "    secret_findings.extend(extra_findings)\n",
        "\n",
        "    return clean_json.encode(\"utf-8\"), sorted(set(secret_findings)), notebook\n",
        "\n",
        "\n",
        "def notebook_summary_text(notebook_data, max_chars=12000):\n",
        "    parts = []\n",
        "\n",
        "    cells = notebook_data.get(\"cells\", [])\n",
        "\n",
        "    for cell in cells[:40]:\n",
        "        cell_type = cell.get(\"cell_type\", \"\")\n",
        "        source = cell.get(\"source\", \"\")\n",
        "\n",
        "        if isinstance(source, list):\n",
        "            source = \"\".join(source)\n",
        "\n",
        "        if str(source).strip():\n",
        "            parts.append(f\"{cell_type.upper()} CELL:\\n{str(source).strip()}\")\n",
        "\n",
        "    text = \"\\n\\n\".join(parts)\n",
        "\n",
        "    return text[:max_chars]\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# OPENAI HELPERS\n",
        "# ==========================================================\n",
        "\n",
        "def call_openai(prompt):\n",
        "    url = \"https://api.openai.com/v1/responses\"\n",
        "\n",
        "    payload = {\n",
        "        \"model\": OPENAI_MODEL,\n",
        "        \"input\": prompt\n",
        "    }\n",
        "\n",
        "    headers = {\n",
        "        \"Authorization\": f\"Bearer {OPENAI_API_KEY}\",\n",
        "        \"Content-Type\": \"application/json\"\n",
        "    }\n",
        "\n",
        "    response = requests.post(url, headers=headers, json=payload)\n",
        "\n",
        "    if response.status_code >= 400:\n",
        "        raise Exception(f\"OpenAI error {response.status_code}: {response.text}\")\n",
        "\n",
        "    data = response.json()\n",
        "\n",
        "    return data[\"output\"][0][\"content\"][0][\"text\"]\n",
        "\n",
        "\n",
        "def generate_github_metadata(notebook_name, notebook_data):\n",
        "    summary = notebook_summary_text(notebook_data)\n",
        "\n",
        "    prompt = f\"\"\"\n",
        "You are preparing a Google Colab / Jupyter notebook for GitHub.\n",
        "\n",
        "Notebook current file name: {notebook_name}\n",
        "\n",
        "Based on the notebook code and markdown, create:\n",
        "\n",
        "1. A clean GitHub repository name.\n",
        "2. A clean notebook file name ending in .ipynb.\n",
        "3. A short GitHub repository description, maximum 150 characters.\n",
        "4. A professional README.md.\n",
        "\n",
        "Use this exact format:\n",
        "\n",
        "REPO_NAME:\n",
        "clean-repo-name\n",
        "\n",
        "NOTEBOOK_FILE_NAME:\n",
        "clean-notebook-name.ipynb\n",
        "\n",
        "DESCRIPTION:\n",
        "short repo description\n",
        "\n",
        "README:\n",
        "# Project Name\n",
        "\n",
        "## Overview\n",
        "Explain what this notebook does.\n",
        "\n",
        "## Features\n",
        "Bullet points.\n",
        "\n",
        "## Tech Stack\n",
        "Mention Python, Jupyter Notebook, Google Colab, and detected libraries if visible.\n",
        "\n",
        "## How to Use\n",
        "Simple steps.\n",
        "\n",
        "## Status\n",
        "Say this notebook is organized for GitHub presentation.\n",
        "\n",
        "Rules:\n",
        "- Repo name must use lowercase letters, numbers, and hyphens only.\n",
        "- Notebook file name must use lowercase letters, numbers, hyphens, and end with .ipynb.\n",
        "- Do not invent fake features.\n",
        "- Do not include secrets, API keys, tokens, credentials, or private information.\n",
        "- Keep it clean and professional.\n",
        "\n",
        "Notebook content:\n",
        "{summary}\n",
        "\"\"\"\n",
        "\n",
        "    try:\n",
        "        result = call_openai(prompt)\n",
        "        result, _ = sanitize_text(result)\n",
        "\n",
        "        repo_name = clean_repo_name(notebook_name)\n",
        "        notebook_file_name = clean_notebook_file_name(notebook_name)\n",
        "        description = f\"Google Colab notebook project: {notebook_name}\"\n",
        "        readme = f\"# {notebook_name}\\n\\nGoogle Colab notebook project.\"\n",
        "\n",
        "        if \"REPO_NAME:\" in result and \"NOTEBOOK_FILE_NAME:\" in result:\n",
        "            repo_part = result.split(\"REPO_NAME:\", 1)[1].split(\"NOTEBOOK_FILE_NAME:\", 1)[0].strip()\n",
        "            file_part = result.split(\"NOTEBOOK_FILE_NAME:\", 1)[1].split(\"DESCRIPTION:\", 1)[0].strip()\n",
        "            desc_part = result.split(\"DESCRIPTION:\", 1)[1].split(\"README:\", 1)[0].strip()\n",
        "            readme_part = result.split(\"README:\", 1)[1].strip()\n",
        "\n",
        "            if repo_part:\n",
        "                repo_name = clean_repo_name(repo_part)\n",
        "\n",
        "            if file_part:\n",
        "                notebook_file_name = clean_notebook_file_name(file_part)\n",
        "\n",
        "            if desc_part:\n",
        "                description = desc_part.replace(\"\\n\", \" \").strip()[:350]\n",
        "\n",
        "            if readme_part:\n",
        "                readme = readme_part.strip()\n",
        "\n",
        "        return repo_name, notebook_file_name, description, readme\n",
        "\n",
        "    except Exception as e:\n",
        "        fallback_repo = clean_repo_name(notebook_name)\n",
        "        fallback_file = clean_notebook_file_name(notebook_name)\n",
        "        fallback_description = f\"Google Colab notebook project: {notebook_name}\"\n",
        "        fallback_readme = f\"\"\"# {notebook_name}\n",
        "\n",
        "## Overview\n",
        "\n",
        "This repository contains a Google Colab / Jupyter notebook project.\n",
        "\n",
        "## Status\n",
        "\n",
        "This notebook is organized for GitHub presentation.\n",
        "\"\"\"\n",
        "        print(f\"OpenAI metadata failed, using fallback. Error: {e}\")\n",
        "        return fallback_repo, fallback_file, fallback_description, fallback_readme\n",
        "\n",
        "\n",
        "# ==========================================================\n",
        "# MAIN\n",
        "# ==========================================================\n",
        "\n",
        "notebook_root = Path(NOTEBOOK_FOLDER)\n",
        "\n",
        "if not notebook_root.exists():\n",
        "    raise Exception(f\"Notebook folder not found: {NOTEBOOK_FOLDER}\")\n",
        "\n",
        "notebooks = list(notebook_root.rglob(\"*.ipynb\"))\n",
        "\n",
        "print(f\"Found {len(notebooks)} notebook files.\")\n",
        "\n",
        "log_path = notebook_root / \"colab_github_upload_log.csv\"\n",
        "\n",
        "with open(log_path, \"w\", newline=\"\", encoding=\"utf-8\") as f:\n",
        "    writer = csv.writer(f)\n",
        "\n",
        "    writer.writerow([\n",
        "        \"OriginalNotebook\",\n",
        "        \"GeneratedRepo\",\n",
        "        \"GeneratedNotebookFile\",\n",
        "        \"HasLocalCode\",\n",
        "        \"RepoExists\",\n",
        "        \"RepoPrivate\",\n",
        "        \"SecretFindings\",\n",
        "        \"Status\",\n",
        "        \"Message\"\n",
        "    ])\n",
        "\n",
        "    for notebook_path in notebooks:\n",
        "        print(\"\\n------------------------------------\")\n",
        "        print(f\"Notebook: {notebook_path}\")\n",
        "\n",
        "        try:\n",
        "            size_mb = notebook_path.stat().st_size / (1024 * 1024)\n",
        "\n",
        "            if size_mb > MAX_NOTEBOOK_SIZE_MB:\n",
        "                message = f\"Skipped. Notebook too large: {size_mb:.2f} MB\"\n",
        "                print(message)\n",
        "\n",
        "                writer.writerow([\n",
        "                    str(notebook_path),\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    \"SKIPPED_LARGE\",\n",
        "                    message\n",
        "                ])\n",
        "\n",
        "                continue\n",
        "\n",
        "            clean_bytes, secret_findings, notebook_data =REDACTED_SECRET
        "\n",
        "            has_local_code = notebook_has_code(notebook_data)\n",
        "\n",
        "            if not has_local_code:\n",
        "                message = \"Skipped. Notebook has no code cells.\"\n",
        "                print(message)\n",
        "\n",
        "                writer.writerow([\n",
        "                    str(notebook_path),\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    False,\n",
        "                    \"\",\n",
        "                    \"\",\n",
        "                    secret_findings,\n",
        "                    \"SKIPPED_NO_CODE\",\n",
        "                    message\n",
        "                ])\n",
        "\n",
        "                continue\n",
        "\n",
        "            repo_name, github_notebook_file_name, description, readme = generate_github_metadata(\n",
        "                notebook_path.stem,\n",
        "                notebook_data\n",
        "            )\n",
        "\n",
        "            repo_info = get_repo_info(repo_name)\n",
        "            exists = repo_info is not None\n",
        "            repo_is_private = bool(repo_info.get(\"private\", False)) if repo_info else False\n",
        "\n",
        "            print(f\"Generated repo: {repo_name}\")\n",
        "            print(f\"Generated notebook file: {github_notebook_file_name}\")\n",
        "            print(f\"Repo exists: {exists}\")\n",
        "            print(f\"Repo private: {repo_is_private}\")\n",
        "\n",
        "            if exists:\n",
        "                if repo_is_private and MAKE_PRIVATE_EXISTING_REPOS_PUBLIC:\n",
        "                    if DRY_RUN:\n",
        "                        message = \"Dry run only. Repo exists and is private. Would convert to public, then skip upload.\"\n",
        "                    else:\n",
        "                        public_message = make_repo_public(repo_name)\n",
        "                        message = f\"{public_message}. Repo already exists, skipped upload.\"\n",
        "\n",
        "                    print(message)\n",
        "\n",
        "                    writer.writerow([\n",
        "                        str(notebook_path),\n",
        "                        repo_name,\n",
        "                        github_notebook_file_name,\n",
        "                        True,\n",
        "                        True,\n",
        "                        True,\n",
        "                        secret_findings,\n",
        "                        \"EXISTING_PRIVATE_REPO_MADE_PUBLIC_SKIPPED\",\n",
        "                        message\n",
        "                    ])\n",
        "\n",
        "                    continue\n",
        "\n",
        "                message = \"Repo already exists. Skipped upload.\"\n",
        "                print(message)\n",
        "\n",
        "                writer.writerow([\n",
        "                    str(notebook_path),\n",
        "                    repo_name,\n",
        "                    github_notebook_file_name,\n",
        "                    True,\n",
        "                    True,\n",
        "                    repo_is_private,\n",
        "                    secret_findings,\n",
        "                    \"SKIPPED_REPO_ALREADY_EXISTS\",\n",
        "                    message\n",
        "                ])\n",
        "\n",
        "                continue\n",
        "\n",
        "            if DRY_RUN:\n",
        "                message = \"Dry run only. Repo does not exist. Would create public repo and upload notebook with generated name, description, and README.\"\n",
        "                print(message)\n",
        "\n",
        "                writer.writerow([\n",
        "                    str(notebook_path),\n",
        "                    repo_name,\n",
        "                    github_notebook_file_name,\n",
        "                    True,\n",
